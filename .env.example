# Copy to `.env` and fill values. Never commit `.env`.

# --- Resend (transactional email) ---
# Use a verified domain/sender in Resend; unverified "from" addresses will fail or only work in test mode.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Optional default recipient for `bun run test:email` (or pass email as CLI arg after --).
# TEST_EMAIL_TO=
# Optional Reply-To on the approval email (applicants see this when they hit "Reply").
# RESEND_REPLY_TO=
# MEMBERSHIP_REPLY_TO=

# --- Membership welcome email (sent when an admin approves a request) ---
# Optional subject line (default is used if unset).
# MEMBERSHIP_APPROVAL_SUBJECT=
# At least one URL is recommended so the email includes real links.
MEMBERSHIP_TELEGRAM_URL=
# MEMBERSHIP_SECONDARY_URL=
# MEMBERSHIP_SECONDARY_LABEL=
# Extra paragraphs (plain text; use a blank line between paragraphs).
# MEMBERSHIP_WELCOME_NOTES=
# Optional raw HTML block appended at the end (trusted admin-only content).
# MEMBERSHIP_WELCOME_EXTRA_HTML=

# --- YouTube (optional but recommended for video length + description) ---
# Create a key: Google Cloud Console → APIs & Services → Credentials → Create credentials → API key
# Restrictions: for local/server calls, use "Application restrictions: None" OR restrict only to YouTube Data API v3.
# The app reads, in order: YOUTUBE_DATA_API_KEY, then YOUTUBE_API_KEY, then GOOGLE_API_KEY.
YOUTUBE_DATA_API_KEY=

# --- Supabase (event posters) ---
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_EVENT_POSTERS_BUCKET=Event-posters
